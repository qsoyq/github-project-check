# Normalize text files to LF in the repository.
* text=auto eol=lf

# Common text formats.
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.py text eol=lf

# Binary formats. Add Git LFS rules here when real large assets are introduced.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
*.7z binary
*.mp4 binary
*.mov binary
*.psd binary
